# GigLeads AI — Environment Variables

# AI Model (Groq/xAI)
XAI_API_KEY=your_groq_api_key_here
XAI_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Database
DATABASE_URL=postgresql://user:pass@localhost:5433/freelance_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=change-this-to-a-random-secret

# RapidAPI — JSearch (Indeed, LinkedIn, Naukri, Glassdoor)
RAPIDAPI_KEY=your_rapidapi_key_here

# RapidAPI — LinkedIn Job Search API + Internships API
RAPIDAPI_KEY_2=your_second_rapidapi_key_here
